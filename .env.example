# Copy to .env and adjust. Docker Compose reads these automatically.

# Backend (Django ORM + django-mongodb-backend)
DJANGO_SECRET_KEY=change-me-in-production
DEBUG=true
# Atlas or local MongoDB — NAME is set separately via MONGODB_DB
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.example.mongodb.net/?retryWrites=true&w=majority&appName=MyApp
MONGODB_DB=freementors

ALLOWED_HOSTS=localhost,127.0.0.1,backend
CORS_ALLOWED_ORIGINS=http://localhost,http://127.0.0.1,http://localhost:8080,http://127.0.0.1:8080,http://localhost:5173,http://127.0.0.1:5173
CSRF_TRUSTED_ORIGINS=http://localhost,http://127.0.0.1,http://localhost:8080,http://127.0.0.1:8080,http://localhost:5173,http://127.0.0.1:5173
GUNICORN_WORKERS=2

# Frontend build-time (browser must reach this URL from the host machine)
VITE_GRAPHQL_URL=http://localhost:8000/graphql/

# Host port mapped to nginx in the frontend container
FRONTEND_PORT=8080
